{
  "name": "qrshare",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "overrides": {
    "serialize-javascript": "^7.0.4"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/copy-404.mjs",
    "preview": "VITE_PUBLIC_BASE=/ npm run build && vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check": "npm-run-all lint typecheck",
    "verify": "npm-run-all check test:unit build",
    "typecheck": "vue-tsc --noEmit",
    "test": "npm-run-all test:unit test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "qr-scanner": "^1.4.2",
    "qrcode": "^1.5.4",
    "vue": "^3.5.25",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.1.5"
  }
}
